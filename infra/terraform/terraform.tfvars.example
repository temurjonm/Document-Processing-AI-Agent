aws_region         = "us-east-2"
instance_name      = "doc-processing-agent"
deployment_mode    = "test"
# Replace with your real public IP in CIDR form, for example "198.51.100.24/32".
allowed_ssh_cidr   = "203.0.113.10/32"
ssh_public_key_path  = "~/.ssh/doc-agent-rsa.pub"
ssh_private_key_path = "~/.ssh/doc-agent-rsa"
# existing_instance_profile_name = "doc-agent-existing-profile"
